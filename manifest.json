{
  "manifest_version": 3,
  "name": "Nodecast",
  "short_name": "Nodecast",
  "version": "1.1.0",
  "description": "Save highlighted text from websites to your local Nodecast knowledge base.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nodecast"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html",
  "commands": {
    "save-selection": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Save selected text to Nodecast"
    },
    "save-page": {
      "suggested_key": {
        "default": "Alt+Shift+P"
      },
      "description": "Save current page to Nodecast"
    },
    "open-nodecast": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Open Nodecast in new tab"
    }
  },
  "icons": {
    "16": "icons/nodecast-icon.png",
    "32": "icons/nodecast-icon.png",
    "48": "icons/nodecast-icon.png",
    "128": "icons/nodecast-icon.png"
  }
}